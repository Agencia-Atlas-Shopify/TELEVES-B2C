            <h3 class="tv-step__title tv-step__title--orange">{{ step1_title }}</h3>
            {%- if step1_text != blank -%}
              <div class="tv-step__text">{{ step1_text }}</div>
            {%- else -%}
              <p><a href="{{ step1_link | default: '#' }}">{{ step1_link_label }}</a></p>
              <p>Use code <strong class="tv-step__code">{{ step1_code }}</strong></p>
