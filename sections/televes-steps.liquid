{%- comment -%}
  Televes "3 Easy Steps" Section - 1:1 clone of store.televes.com
  Self-contained: HTML + CSS + JS
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | default: 'Cut the cord and get free tv at home'
  assign subheading = section.settings.subheading | default: 'In three easy steps'
  assign step1_title = section.settings.step1_title | default: 'Choose'
  assign step1_text = section.settings.step1_text
  assign step1_link = section.settings.step1_link
  assign step1_link_label = section.settings.step1_link_label | default: 'Get discounted advice from Antenna Man!'
  assign step1_code = section.settings.step1_code | default: 'TELEVES'
  assign step2_title = section.settings.step2_title | default: 'INSTALL the antenna'
  assign step2_text = section.settings.step2_text
  assign step2_link = section.settings.step2_link
  assign step2_link_label = section.settings.step2_link_label | default: 'installer network'
  assign step3_title = section.settings.step3_title | default: 'Enjoy!'
  assign step3_text = section.settings.step3_text | default: 'Start watching free TV!'
-%}

{%- comment -%} Background images that need Liquid asset_url {%- endcomment -%}
<style>
  .tv-step--1 .tv-step__tip { background-image: url('{{ 'tv-steps-punta.svg' | asset_url }}'); }
  .tv-step--2 .tv-step__tail { background-image: url('{{ 'tv-steps-cola-dos.svg' | asset_url }}'); }
  .tv-step--2 .tv-step__tip { background-image: url('{{ 'tv-steps-punta.svg' | asset_url }}'); }
  .tv-step--3 .tv-step__tail { background-image: url('{{ 'tv-steps-cola-tres.svg' | asset_url }}'); }
  @media (max-width: 1023px) {
    .tv-step--1 .tv-step__tip { background-image: url('{{ 'tv-steps-punta-flecha-mvl.svg' | asset_url }}'); }
    .tv-step--2 .tv-step__tail { background-image: url('{{ 'tv-steps-dos-mvl.svg' | asset_url }}'); }
    .tv-step--2 .tv-step__tip { background-image: url('{{ 'tv-steps-punta-flecha-mvl.svg' | asset_url }}'); }
    .tv-step--3 .tv-step__tail { background-image: url('{{ 'tv-steps-tres-mvl.svg' | asset_url }}'); }
  }
</style>

<section class="tv-steps" id="tv-steps-{{ section.id }}">
  <div class="tv-steps__container">
    <h2 class="tv-steps__heading">{{ heading }}</h2>
    <h3 class="tv-steps__subheading">{{ subheading }}</h3>

    <div class="tv-steps__row">

      {%- comment -%} ====== STEP 1: Choose ====== {%- endcomment -%}
      <div class="tv-step tv-step--1 tv-steps__item" data-tv-step>
        <div class="tv-step__tail"></div>
        <div class="tv-step__body tv-step__body--white">
          <div class="tv-step__content" style="padding: 0 10px;">
            {%- comment -%} Icon: ecommerce-icons e90f "cursor" {%- endcomment -%}
