            <h3 class="tv-step__title tv-step__title--enjoy">{{ step3_title }}</h3>
            {%- if step3_text != blank -%}
              <div class="tv-step__text">{{ step3_text }}</div>
            {%- else -%}
              <p>Start watching free TV!</p>
            {%- endif -%}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  /* Scroll-triggered animation for steps */
  (function() {
    var section = document.getElementById('tv-steps-{{ section.id }}');
    if (!section) return;
    var items = section.querySelectorAll('[data-tv-step]');
    if (!items.length) return;

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var allItems = section.querySelectorAll('[data-tv-step]');
            allItems.forEach(function(item, i) {
              item.style.animationDelay = (i * 0.4) + 's';
              item.classList.add('tv-steps--animate');
            });
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });
      observer.observe(section);
    } else {
      items.forEach(function(item) {
        item.classList.add('tv-steps--animate');
      });
    }
  })();
</script>

{% stylesheet %}
  /* ============================================
     TELEVES 3 EASY STEPS - 1:1 Clone
     Reference: store.televes.com homepage
     ============================================ */

  /* ---- Animation ---- */
  @keyframes tv-enterSteps {
    0% { opacity: 0; transform: translateX(-20px); }
    100% { opacity: 1; transform: translateX(0); }
  }

  /* ---- Section wrapper ---- */
  .tv-steps {
    background: linear-gradient(0deg, rgb(227, 227, 227) 0%, rgb(245, 245, 245) 100%);
    font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: #333;
  }

  .tv-steps *,
  .tv-steps *::before,
  .tv-steps *::after {
    box-sizing: border-box;
  }

  .tv-steps__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  /* ---- Headings ---- */
  .tv-steps__heading {
    font-family: 'Raleway', 'Open Sans', Arial, Helvetica, sans-serif;
    font-size: 44px;
    line-height: 50px;
    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    color: #333;
    margin: 0 0 0 0;
    -webkit-font-smoothing: antialiased;
  }

  .tv-steps__subheading {
    font-family: 'Raleway', 'Open Sans', Arial, Helvetica, sans-serif;
    font-size: 20px;
    line-height: 26px;
    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    color: #333;
    margin: 0 0 40px 0;
    -webkit-font-smoothing: antialiased;
  }

  /* ---- Steps row (flex) ---- */
  .tv-steps__row {
    display: flex;
    flex-wrap: wrap;
    margin: 0;
    align-items: stretch;
  }

  /* ---- Each step item (initial state for animation) ---- */
  .tv-steps__item {
    opacity: 0;
    transform: translateX(-20px);
  }

  .tv-steps__item.tv-steps--animate {
    animation-name: tv-enterSteps;
    animation-duration: 0.5s;
    animation-fill-mode: forwards;
    animation-timing-function: ease-out;
  }

  /* ---- Step card ---- */
  .tv-step {
    display: flex;
    flex-wrap: nowrap;
    width: calc((100% - 70px) / 3);
  }

  .tv-step--2 {
    flex-grow: 8;
  }

  /* ---- Step body ---- */
  .tv-step__body {
    flex-grow: 8;
    padding: 20px 0;
    display: flex;
    flex-wrap: wrap;
  }

  .tv-step__body--white {
    background-color: #fff;
  }

  .tv-step__body--orange {
    background-color: #ffa100;
    border-radius: 0 6px 6px 0;
  }

  /* ---- Step 1 body width (matching inline style from reference) ---- */
  .tv-step--1 .tv-step__body {
    width: calc(100% - 64px);
  }

  /* ---- Step content ---- */
  .tv-step__content {
    position: relative;
    width: 100%;
    padding: 0 15px;
    flex-basis: 0;
    flex-grow: 1;
    max-width: 100%;
  }

  .tv-step__content--white {
    color: #fff;
  }

  /* ---- Step icons ---- */
  .tv-step__icon {
    display: block;
    margin-bottom: 4px;
  }

  .tv-step__icon--orange {
    color: #ffa100;
    fill: #ffa100;
    width: 32px;
    height: 32px;
  }

  .tv-step__icon--enjoy {
    width: 80px;
    height: 80px;
    fill: currentColor;
    position: absolute;
    top: -56px;
    text-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
    filter: drop-shadow(0 0 5px rgba(0, 0, 0, 0.3));
  }

  /* ---- Step titles ---- */
  .tv-step__title {
    font-family: 'Raleway', 'Open Sans', Arial, Helvetica, sans-serif;
    font-size: 20px;
    line-height: 26px;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .tv-step__title--orange {
    color: #ffa100;
  }

  .tv-step__title--enjoy {
    color: inherit;
    margin-top: 32px;
  }

  /* ---- Step text ---- */
  .tv-step__text p,
  .tv-step p {
    margin: 0 0 16px 0;
    font-size: 14px;
    line-height: 1.4;
    color: #333;
  }

  .tv-step p:last-child {
    margin-bottom: 0;
  }

  .tv-step__content--white p {
    color: #fff;
  }

  .tv-step a {
    color: #f6a400;
    text-decoration: none;
    transition: all 0.3s;
  }

  .tv-step a:hover {
    color: #000;
    text-decoration: none;
  }

  .tv-step__content--white a {
    color: #fff;
    text-decoration: underline;
  }

  .tv-step__content--white a:hover {
    color: #fff;
    opacity: 0.8;
  }

  .tv-step__code {
    color: #666;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
  }

  /* ---- Tail (left decorative shape) ---- */
  .tv-step__tail {
    background-size: cover;
    background-repeat: no-repeat;
  }

  .tv-step--1 .tv-step__tail {
    display: none;
  }

  .tv-step--2 .tv-step__tail {
    width: 99px;
    height: 100%;
    background-position-x: left;
  }

  .tv-step--3 .tv-step__tail {
    width: 99px;
    height: 100%;
    background-position-x: left;
  }

  /* ---- Tip (right decorative shape) ---- */
  .tv-step__tip {
    width: 44px;
    height: 100%;
    background-size: cover;
    background-repeat: no-repeat;
    background-position-x: right;
    flex-shrink: 0;
  }

  /* ---- Arrows between steps ---- */
  .tv-steps__arrow {
    width: 89px;
    margin-left: -30px;
    margin-right: -34px;
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .tv-steps__arrow img {
    height: 100%;
    width: 100%;
  }

  .tv-steps__arrow-mobile {
    display: none;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */

  @media (max-width: 1023px) {
    .tv-steps__row {
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }

    .tv-steps__arrow {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    }

    .tv-steps__arrow-desktop {
      display: none;
    }

    .tv-steps__arrow-mobile {
      display: inline-block;
      transform: none;
      margin-top: 10px;
    }

    .tv-step {
      width: 100%;
      flex-wrap: wrap;
    }

    .tv-step--2 {
      margin-top: 10px;
    }

    .tv-step--3 {
      margin-top: 10px;
    }

    /* Step 1 mobile */
    .tv-step--1 .tv-step__body {
      border-radius: 0 6px 0 0;
      width: 100%;
    }

    .tv-step--1 .tv-step__tip {
      width: 100%;
      height: auto;
      min-height: 20px;
      background-repeat: no-repeat;
      background-size: contain;
      margin-top: -1px;
      background-position-x: left;
    }

    /* Step 2 mobile */
    .tv-step--2 .tv-step__tail {
      width: 63px;
      height: 100%;
      min-height: 146px;
      background-repeat: no-repeat;
      background-size: cover;
    }

    .tv-step--2 .tv-step__body {
      border-radius: 0 6px 0 0;
    }

    .tv-step--2 .tv-step__tip {
      width: 100%;
      height: auto;
      min-height: 20px;
      background-repeat: no-repeat;
      background-size: contain;
      margin-top: -1px;
      background-position-x: left;
    }

    /* Step 3 mobile */
    .tv-step--3 .tv-step__tail {
      width: 74px;
      height: 100%;
      min-height: 146px;
      background-repeat: no-repeat;
      background-size: cover;
    }

    .tv-step--3 .tv-step__body {
      border-radius: 0 6px 0 0;
    }

    /* Enjoy icon smaller on mobile */
    .tv-step__icon--enjoy {
      font-size: 32px;
      width: 32px;
      height: 32px;
      top: -5px;
    }
  }

  @media (max-width: 767px) {
    .tv-steps__container {
      padding: 60px 15px;
    }

    .tv-steps__heading {
      font-size: 32px;
      line-height: 38px;
    }
  }

  @media (max-width: 500px) {
    .tv-steps__heading {
      font-size: 28px;
      line-height: 34px;
    }

    .tv-step__title {
      font-size: 18px;
      line-height: 22px;
    }

    .tv-step__icon--orange {
      width: 28px;
      height: 28px;
    }
  }
{% endstylesheet %}

