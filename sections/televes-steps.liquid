        </div>
        <div class="tv-step__tip"></div>
      </div>

      {%- comment -%} Arrow 1 {%- endcomment -%}
      <div class="tv-steps__arrow tv-steps__item" data-tv-step>
        <img class="tv-steps__arrow-desktop" src="{{ 'tv-steps-flecha.svg' | asset_url }}" alt="" loading="lazy">
        <img class="tv-steps__arrow-mobile" src="{{ 'tv-steps-flecha-mvl.svg' | asset_url }}" alt="" loading="lazy">
      </div>

      {%- comment -%} ====== STEP 2: Install ====== {%- endcomment -%}
      <div class="tv-step tv-step--2 tv-steps__item" data-tv-step>
        <div class="tv-step__tail"></div>
        <div class="tv-step__body tv-step__body--white">
          <div class="tv-step__content">
            {%- comment -%} Icon: ecommerce-icons e916 "self-installation" {%- endcomment -%}
            <svg class="tv-step__icon tv-step__icon--orange" width="32" height="32" viewBox="0 0 1024 1024" fill="currentColor"><path d="M609.306 307.763c-19.789 0-35.84 16.051-35.84 35.84v172.288c0 14.31 8.525 27.264 21.658 32.922 70.016 30.131 115.251 98.842 115.251 175.027 0 45.466-16.282 88.653-44.672 122.47v-119.27c0-13.005-7.040-25.011-18.432-31.334l-108.902-60.57c-10.752-5.965-23.782-6.016-34.586-0.154l-111.027 60.57c-11.52 6.272-18.688 18.355-18.688 31.462v119.27c-28.39-33.818-44.672-77.005-44.672-122.47 0-76.186 45.235-144.87 115.251-175.027 13.158-5.658 21.658-18.611 21.658-32.922v-170.445c0-19.789-16.051-35.84-35.84-35.84s-35.84 16.051-35.84 35.84v148.045c-83.891 45.594-136.934 133.581-136.934 230.349s51.712 182.784 134.835 229.094c11.11 6.195 24.653 6.016 35.61-0.41s17.69-18.202 17.69-30.899v-173.338l75.034-40.909 73.242 40.73v173.517c0 12.698 6.733 24.474 17.69 30.899s24.499 6.579 35.61 0.41c83.098-46.31 134.733-134.093 134.733-229.094s-53.018-184.755-136.934-230.349v-149.888c0-19.789-16.051-35.84-35.84-35.84zM663.168-61.44h-400.358c-34.15 0-61.926 27.776-61.926 61.926l-1.28 343.091c0 76.672 62.259 138.931 138.803 138.931h90.163c19.789 0 35.84-16.051 35.84-35.84s-16.051-35.84-35.84-35.84h-90.163c-37.018 0-67.123-30.106-67.123-67.123l1.229-333.466h390.63c25.805 0 47.744 18.458 52.173 43.878l36.813 211.738c1.843 10.624-0.947 20.992-7.885 29.235s-16.691 12.774-27.469 12.774h-346.906c-19.789 0-35.84 16.051-35.84 35.84s16.051 35.84 35.84 35.84h346.931c31.821 0 61.824-13.978 82.304-38.323s29.107-56.32 23.654-87.654l-36.813-211.738c-10.419-59.853-62.054-103.27-122.778-103.27zM272.563 0.691v-0.077s0 0.051 0 0.077z" transform="translate(0, 960) scale(1, -1)"/></svg>
            <h3 class="tv-step__title tv-step__title--orange">{{ step2_title }}</h3>
            {%- if step2_text != blank -%}
              <div class="tv-step__text">{{ step2_text }}</div>
            {%- else -%}
              <p>Need help? Use our <a href="{{ step2_link | default: '#' }}">{{ step2_link_label }}</a></p>
            {%- endif -%}
          </div>
        </div>
        <div class="tv-step__tip"></div>
      </div>

      {%- comment -%} Arrow 2 {%- endcomment -%}
      <div class="tv-steps__arrow tv-steps__item" data-tv-step>
        <img class="tv-steps__arrow-desktop" src="{{ 'tv-steps-flecha.svg' | asset_url }}" alt="" loading="lazy">
        <img class="tv-steps__arrow-mobile" src="{{ 'tv-steps-flecha-mvl.svg' | asset_url }}" alt="" loading="lazy">
      </div>

      {%- comment -%} ====== STEP 3: Enjoy! ====== {%- endcomment -%}
      <div class="tv-step tv-step--3 tv-steps__item" data-tv-step>
        <div class="tv-step__tail"></div>
        <div class="tv-step__body tv-step__body--orange">
          <div class="tv-step__content tv-step__content--white">
            {%- comment -%} Icon: ecommerce-icons e93e "confetti" {%- endcomment -%}
