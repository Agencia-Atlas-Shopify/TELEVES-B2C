{% stylesheet %}
/* ===== Products Section ===== */
.tv-prod {
  margin-bottom: 80px;
}

.tv-prod__wrapper {
  max-width: 1400px;
  margin: auto;
  padding-left: 20px;
  padding-right: 20px;
}

/* Header */
.tv-prod__header {
  text-align: center;
}

.tv-prod__separator {
  display: block;
  margin: 10px auto 20px;
  width: 80px;
  height: 4px;
  border-radius: 4px;
  background-color: #ffa500;
}

.tv-prod__title {
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  font-size: 44px;
  line-height: 50px;
  font-weight: 700;
  text-transform: uppercase;
  margin: 0 0 0 0;
  padding-left: 20px;
  padding-right: 20px;
  color: #333;
}

/* Grid */
.tv-prod__grid {
  display: flex;
}

.tv-prod__area {
  display: flex;
  flex-direction: column;
  width: calc(100% / 4);
  align-items: center;
  margin-bottom: 0;
}

/* Area label */
.tv-prod__area-label {
  background-size: contain;
  background-position: center bottom;
  background-repeat: no-repeat;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  text-transform: uppercase;
  padding-bottom: 10px;
  min-height: 211px;
}

.tv-prod__area:hover .tv-prod__area-label {
  color: #212121;
  filter: opacity(0.5);
  transition: 0.5s;
}

/* Card */
.tv-prod__card {
  width: 100%;
  flex: 1;
}

.tv-prod__card-inner {
  margin: -8px 10px 20px 10px;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  border-radius: 12px;
  box-shadow: 0px 0px 20px 0px rgba(0,0,0,0.15);
  padding: 12px;
  position: relative;
  flex: 1;
}

.tv-prod__card-inner--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200px;
}

.tv-prod__empty {
  font-family: 'Open Sans', Arial, sans-serif;
  font-size: 14px;
  color: #999;
  text-align: center;
}

/* Badge */
.tv-prod__badge {
  position: absolute;
  z-index: 10;
}

.tv-prod__badge a {
  display: flex;
  align-items: center;
  color: #f6a400;
  font-size: 12px;
  line-height: 12px;
  background-color: rgba(246, 164, 0, 0.3);
  padding: 3px 5px;
  text-decoration: none;
  transition: all 0.3s;
}

.tv-prod__badge a:hover {
  background: #f6a400;
  background: linear-gradient(0deg, rgba(51,51,51,1) 50%, rgba(246,164,0,1) 50%);
  background-size: 200% 200%;
  background-position-y: 0;
  animation: tv-prod-grad .1s ease forwards;
  color: #fff;
}

@keyframes tv-prod-grad {
  to { background-position-y: 100%; }
}

.tv-prod__badge svg {
  margin-right: 5px;
}

.tv-prod__badge strong {
  font-weight: 600;
}

/* Image */
.tv-prod__img-link {
  display: block;
  text-decoration: none;
}

.tv-prod__img-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: transparent;
}

.tv-prod__img-wrap img {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  margin: auto;
  max-width: 100%;
  height: auto;
  display: block;
  margin-top: -20px;
}

/* Info */
.tv-prod__info {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  margin-top: -40px;
}

.tv-prod__name-link {
  text-decoration: none;
  color: #333;
}

.tv-prod__name-link:hover {
  color: #000;
}

.tv-prod__name {
  font-family: 'Raleway', 'Open Sans', Arial, Helvetica, sans-serif;
  font-size: 20px;
  line-height: 24px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 0;
  color: #333;
  text-align: left;
}

.tv-prod__description {
  font-family: 'Open Sans', Arial, sans-serif;
  font-size: 14px;
  line-height: 1.42857143;
  color: #333;
  margin: 12px 0;
  text-align: left;
}

.tv-prod__specs {
  text-align: left;
  font-family: 'Open Sans', Arial, sans-serif;
  font-size: 14px;
  line-height: 18px;
  color: #333;
}

/* Price */
.tv-prod__price-row {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  padding: 20px 0 8px;
  flex-grow: 1;
}

.tv-prod__price {
  font-family: 'Open Sans', Arial, sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: #333;
}

/* Add to cart */
.tv-prod__actions {
  margin: 4px 0 0 0;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tv-prod__actions form {
  width: 100%;
  margin: 0;
}

.tv-prod__add-btn {
  border: none;
  padding: 8px 40px;
  border-radius: 40px;
  font-weight: 700;
  color: #fff;
  background: #f6a400;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: none;
  cursor: pointer;
  width: 100%;
  height: 40px;
  font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 16px;
  transition: all 0.3s;
}

.tv-prod__add-btn:hover {
  background: #f6a400;
  background: linear-gradient(0deg, rgba(51,51,51,1) 50%, rgba(246,164,0,1) 50%);
  background-size: 200% 200%;
  background-position-y: 0;
  animation: tv-prod-grad .1s ease forwards;
  color: #fff;
}

/* ===== Responsive ===== */
@media (max-width: 1190px) {
  .tv-prod__grid {
    flex-wrap: wrap;
    justify-content: center;
  }
  .tv-prod__area {
    width: calc(100% / 3);
  }
  .tv-prod__area-label {
    min-height: 237px;
  }
}

@media (max-width: 900px) {
  .tv-prod__area {
    width: calc(100% / 2);
  }
  .tv-prod__area-label {
    min-height: 188px;
  }
}

@media (max-width: 550px) {
  .tv-prod__area {
    width: 100%;
    margin-top: -1px;
  }
  .tv-prod__area-label {
    background-size: cover;
  }
  .tv-prod__card-inner {
    margin: -8px 0 18px 0;
  }
  .tv-prod__area--1,
  .tv-prod__area--3 {
    background: #9e9e9e;
  }
}

@media (max-width: 767px) {
  .tv-prod__add-btn {
    font-size: 14px;
  }
}

@media (max-width: 500px) {
  .tv-prod__title {
    font-size: 34px;
    line-height: 40px;
  }
}
{% endstylesheet %}

