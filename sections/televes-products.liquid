                  <strong>{{ badge_text }}</strong>
                </a>
              </div>
              <a href="{{ p.url }}" class="tv-prod__img-link">
                <div class="tv-prod__img-wrap">
                  {%- if p.featured_image != blank -%}
                    <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.featured_image.alt | escape }}" width="400" height="400" loading="lazy">
                  {%- endif -%}
                </div>
              </a>
