{%- comment -%}
  Televes "An antenna for every area" Products Section
  1:1 clone of store.televes.com — products selectable from Shopify customizer
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | default: 'An antenna for every area'

  assign area1_label = section.settings.area1_label | default: 'indoor/urban'
  assign area2_label = section.settings.area2_label | default: 'metro/suburban'
  assign area3_label = section.settings.area3_label | default: 'towns/rural'
  assign area4_label = section.settings.area4_label | default: 'countryside'

  assign product1 = section.settings.product1
  assign product2 = section.settings.product2
  assign product3 = section.settings.product3
  assign product4 = section.settings.product4

  assign badge_text = section.settings.badge_text | default: '30-day refund'
  assign badge_link = section.settings.badge_link | default: '/pages/return-conditions'
-%}

{%- comment -%} Background images that need Liquid asset_url {%- endcomment -%}
<style>
  .tv-prod__area--1 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-1.svg' | asset_url }}'); }
  .tv-prod__area--2 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-2.svg' | asset_url }}'); }
  .tv-prod__area--3 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-3.svg' | asset_url }}'); }
  .tv-prod__area--4 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-4.svg' | asset_url }}'); }

  @media (max-width: 900px) {
    .tv-prod__area--1 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-1-tbl.svg' | asset_url }}'); }
    .tv-prod__area--2 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-2-tbl.svg' | asset_url }}'); }
    .tv-prod__area--3 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-3-tbl.svg' | asset_url }}'); }
    .tv-prod__area--4 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-4-tbl.svg' | asset_url }}'); }
  }

  @media (max-width: 550px) {
    .tv-prod__area--1 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-1-mvl.svg' | asset_url }}'); }
    .tv-prod__area--2 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-2-mvl.svg' | asset_url }}'); }
    .tv-prod__area--3 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-3-mvl.svg' | asset_url }}'); }
    .tv-prod__area--4 .tv-prod__area-label { background-image: url('{{ 'tv-products-area-4-mvl.svg' | asset_url }}'); }
  }
</style>

<section class="tv-prod">
  <div class="tv-prod__wrapper">
    <div class="tv-prod__header">
      <div class="tv-prod__separator"></div>
      <h2 class="tv-prod__title">{{ heading }}</h2>
    </div>

    <div class="tv-prod__grid">
      {%- comment -%} ====== AREA 1 ====== {%- endcomment -%}
      <div class="tv-prod__area tv-prod__area--1">
        <div class="tv-prod__area-label">{{ area1_label }}</div>
        <div class="tv-prod__card">
          {%- if product1 != blank -%}
