{%- comment -%}
  Pre-header bar - Televes store reference (1:1 clone)
  Left: Navigation links (Support, About us, Contact us)
  Right: User icon + Account links (Log in, Create account)
  Hidden on mobile (<768px)
{%- endcomment -%}

<div class="televes-pre-header__wrapper">
  <div class="televes-pre-header">
    {%- comment -%} Left side: Navigation links (order: 0) {%- endcomment -%}
    <div class="televes-pre-header__nav">
      <div class="televes-pre-header__nav-inner">
        {%- assign has_nav_links = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            {%- assign has_nav_links = true -%}
            <div class="televes-pre-header__nav-item" {{ block.shopify_attributes }}>
              <a class="televes-pre-header__nav-link" href="{{ block.settings.link }}">
                {{- block.settings.label -}}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- unless has_nav_links -%}
          <div class="televes-pre-header__nav-item">
            <a class="televes-pre-header__nav-link" href="/pages/support">Support</a>
          </div>
          <div class="televes-pre-header__nav-item">
            <a class="televes-pre-header__nav-link" href="/pages/about-us">About us</a>
          </div>
          <div class="televes-pre-header__nav-item">
            <a class="televes-pre-header__nav-link" href="/pages/contact-us">Contact us</a>
          </div>
        {%- endunless -%}
      </div>
    </div>

    {%- comment -%} Right side: User icon (order: 1) {%- endcomment -%}
    {%- if section.settings.show_account_links -%}
      <div class="televes-pre-header__user-icon">
        <span class="televes-pre-header__user-icon-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </span>
      </div>

      {%- comment -%} Account links (margin-left: auto, pushed to far right) {%- endcomment -%}
      <ul class="televes-pre-header__account-links">
        {%- if customer -%}
          <li>
            <a href="{{ routes.account_url }}">
              {{ customer.first_name | default: section.settings.account_label }}
            </a>
          </li>
          <li>
            <a href="{{ routes.account_logout_url }}">
              {{ section.settings.logout_label }}
            </a>
          </li>
        {%- else -%}
          <li>
            <a href="{{ routes.account_login_url }}">
              {{ section.settings.login_label }}
            </a>
          </li>
          <li>
            <a href="{{ routes.account_register_url }}">
              {{ section.settings.register_label }}
            </a>
          </li>
        {%- endif -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ============================================
     Pre-header wrapper
     ============================================ */
  .televes-pre-header__wrapper {
    margin-bottom: 0;
    z-index: 500;
  }

  @media (min-width: 769px) {
    .televes-pre-header__wrapper {
      border-bottom: 1px solid #e8e8e8;
    }
  }

  @media (max-width: 768px) {
    .televes-pre-header__wrapper {
      display: none;
    }
  }

  @media (max-width: 1432px) {
    .televes-pre-header__wrapper {
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  /* ============================================
     Pre-header inner container
     ============================================ */
  .televes-pre-header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 32px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    padding-right: 6px;
    font-size: 12px;
    font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 400;
    line-height: 1.42857143;
    color: #333;
  }

  /* ============================================
     Left navigation links
     ============================================ */
  .televes-pre-header__nav {
    order: 0;
  }

  .televes-pre-header__nav-inner {
    display: flex;
    align-items: center;
  }

  @media (max-width: 575px) {
    .televes-pre-header__nav-inner {
      display: none;
    }
  }

  .televes-pre-header__nav-item {
    padding-right: 32px;
  }

  .televes-pre-header__nav-link {
    color: #afafaf;
    text-decoration: none;
    transition: all 0.3s;
    cursor: pointer;
    outline: 0;
  }

  .televes-pre-header__nav-link:hover {
    color: #000;
    text-decoration: none;
  }

  /* ============================================
     User icon
     ============================================ */
  .televes-pre-header__user-icon {
    list-style: none;
    order: 1;
  }

  .televes-pre-header__user-icon-inner {
    display: inline-flex;
    align-items: center;
    font-size: 20px;
    margin-right: 4px;
    cursor: pointer;
    color: #333;
  }

  /* ============================================
     Account links
     ============================================ */
  .televes-pre-header__account-links {
    display: none;
    margin: 0;
    padding: 0;
    list-style: none;
    margin-left: auto;
    font-size: 0;
  }

  @media (min-width: 769px) {
    .televes-pre-header__account-links {
      display: inline-block;
    }
  }

  .televes-pre-header__account-links > li {
    display: inline-block;
    vertical-align: top;
    font-size: 14px;
    margin: 0 0 0 15px;
    padding: 5px 0;
    border-bottom: 2px solid transparent;
  }

  .televes-pre-header__account-links > li > a {
    padding: 4px 0;
    margin: 0;
    border-bottom: 2px solid transparent;
    color: #666;
    text-decoration: none;
    transition: all 0.3s;
    line-height: 1.4;
    cursor: pointer;
    outline: 0;
  }

  .televes-pre-header__account-links > li > a:hover {
    cursor: pointer;
    color: #333;
    border-bottom: 2px solid #333;
    text-decoration: none;
  }

  /* ============================================
     Mobile: Account links as dropdown
     ============================================ */
  @media (max-width: 768px) {
    .televes-pre-header__user-icon {
      display: none;
    }

    .televes-pre-header__nav {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-header",
  "class": "televes-pre-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Account links"
    },
    {
      "type": "checkbox",
      "id": "show_account_links",
      "label": "Show account links",
      "default": true
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login label",
      "default": "Log in"
    },
    {
      "type": "text",
      "id": "register_label",
      "label": "Register label",
      "default": "Create account"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account label",
      "default": "My Account"
    },
    {
      "type": "text",
      "id": "logout_label",
      "label": "Logout label",
      "default": "Log out"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pre-header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "label": "Support"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "About us"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "Contact us"
          }
        }
      ]
    }
  ]
}
{% endschema %}
