<div class="pre-header-wrapper color-{{ section.settings.color_scheme }}">
  <div class="pre-header section--{{ section.settings.section_width }}">
    {%- comment -%} Left side: Navigation links {%- endcomment -%}
    <div class="pre-header__links-left">
      {%- assign has_nav_links = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_link' -%}
          {%- assign has_nav_links = true -%}
          <div class="pre-header__link-item" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="pre-header__link">
              {{- block.settings.label -}}
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- unless has_nav_links -%}
        <div class="pre-header__link-item">
          <a href="/pages/support" class="pre-header__link">Support</a>
        </div>
        <div class="pre-header__link-item">
          <a href="/pages/about-us" class="pre-header__link">About us</a>
        </div>
        <div class="pre-header__link-item">
          <a href="/pages/contact-us" class="pre-header__link">Contact us</a>
        </div>
      {%- endunless -%}
    </div>

    {%- comment -%} Right side: Account links {%- endcomment -%}
    {%- if section.settings.show_account_links -%}
      <div class="pre-header__links-right">
        <div class="pre-header__account">
          {%- if section.settings.show_account_icon -%}
            <span class="pre-header__account-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
          {%- endif -%}

          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="pre-header__link">
              {{ customer.first_name | default: section.settings.account_label }}
            </a>
            <a href="{{ routes.account_logout_url }}" class="pre-header__link">
              {{ section.settings.logout_label }}
            </a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="pre-header__link">
              {{ section.settings.login_label }}
            </a>
            <a href="{{ routes.account_register_url }}" class="pre-header__link">
              {{ section.settings.register_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .pre-header-wrapper {
    border-bottom: 1px solid var(--pre-header-border-color, #e8e8e8);
  }

  .pre-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 32px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    font-size: 12px;
    font-family: var(--font-body--family, 'Open Sans', Arial, Helvetica, sans-serif);
  }

  .pre-header.section--page-width {
    max-width: var(--page-width, 1400px);
  }

  .pre-header.section--full-width {
    max-width: 100%;
  }

  .pre-header__links-left {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .pre-header__link-item {
    padding-right: 32px;
  }

  .pre-header__link-item:last-child {
    padding-right: 0;
  }

  .pre-header__links-right {
    display: flex;
    align-items: center;
    margin-left: auto;
  }

  .pre-header__account {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .pre-header__account-icon {
    display: flex;
    align-items: center;
    margin-right: -5px;
    color: var(--pre-header-text-color, #333);
  }

  .pre-header__link {
    color: var(--pre-header-link-color, #afafaf);
    text-decoration: none;
    transition: all 0.3s ease;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    line-height: 1.4;
  }

  .pre-header__link:hover {
    color: var(--pre-header-link-hover-color, #333);
    border-bottom-color: var(--pre-header-link-hover-color, #333);
    text-decoration: none;
  }

  .pre-header__links-right .pre-header__link {
    color: var(--pre-header-account-link-color, #666);
  }

  .pre-header__links-right .pre-header__link:hover {
    color: var(--pre-header-link-hover-color, #333);
    border-bottom-color: var(--pre-header-link-hover-color, #333);
  }

  @media screen and (max-width: 767px) {
    .pre-header-wrapper {
      display: none;
    }
  }

  @media screen and (max-width: 1432px) {
    .pre-header {
      padding-left: 16px;
      padding-right: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-header",
  "class": "pre-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Account links"
    },
    {
      "type": "checkbox",
      "id": "show_account_links",
      "label": "Show account links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account_icon",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login label",
      "default": "Log in"
    },
    {
      "type": "text",
      "id": "register_label",
      "label": "Register label",
      "default": "Create account"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account label",
      "default": "My Account"
    },
    {
      "type": "text",
      "id": "logout_label",
      "label": "Logout label",
      "default": "Log out"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pre-header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "label": "Support"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "About us"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "Contact us"
          }
        }
      ]
    }
  ]
}
{% endschema %}
