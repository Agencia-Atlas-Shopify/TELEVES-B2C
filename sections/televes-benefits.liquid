{%- comment -%}
  Televes "Benefits" Section - 1:1 clone of store.televes.com
  Self-contained: HTML + CSS + JS
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | default: 'benefits'
  assign subheading = section.settings.subheading | default: 'of installing an antenna at home'
  assign cta_text = section.settings.cta_text | default: 'Get yours'
  assign cta_link = section.settings.cta_link | default: '/collections/tv-antennas'

  assign b1_title = section.settings.b1_title | default: 'enjoy!'
  assign b1_text = section.settings.b1_text | default: 'Watch your favorite sports, prime time shows, and local news'
  assign b2_title = section.settings.b2_title | default: 'no fees'
  assign b2_text = section.settings.b2_text | default: 'No monthly fees: Save up to $1,500 per year'
  assign b3_title = section.settings.b3_title | default: 'antenna RECOMMENDATION'
  assign b3_text = section.settings.b3_text | default: 'Personalized phone/email support and recommendation tool'
  assign b4_title = section.settings.b4_title | default: 'easy installation'
  assign b4_text = section.settings.b4_text | default: 'Three simple steps'
  assign b5_title = section.settings.b5_title | default: '30 DAY RETURNS'
  assign b5_text = section.settings.b5_text | default: 'Try your antenna for 30 days'
-%}

