{% stylesheet %}
/* ===== Benefits Section ===== */
.tv-benefits {
  background: rgb(227, 227, 227);
  background: linear-gradient(0deg, rgb(227, 227, 227) 0%, rgba(245, 245, 245, 1) 100%);
}

.tv-benefits__container {
  width: 100%;
  padding-right: 15px;
  padding-left: 15px;
  margin-right: auto;
  margin-left: auto;
  padding-top: 80px;
  padding-bottom: 80px;
}

@media (min-width: 576px) {
  .tv-benefits__container { max-width: 540px; }
}
@media (min-width: 768px) {
  .tv-benefits__container { max-width: 720px; }
}
@media (min-width: 992px) {
  .tv-benefits__container { max-width: 960px; }
}
@media (min-width: 1200px) {
  .tv-benefits__container { max-width: 1200px; }
}
@media (min-width: 1420px) {
  .tv-benefits__container { max-width: 1400px; }
}

/* Headings */
.tv-benefits__title {
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  font-size: 44px;
  line-height: 50px;
  font-weight: 700;
  text-transform: uppercase;
  text-align: center;
  margin: 0;
  color: #333;
}

.tv-benefits__subtitle {
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  font-size: 20px;
  line-height: 26px;
  font-weight: 700;
  text-transform: uppercase;
  text-align: center;
  margin: 0 0 40px 0;
  color: #333;
}

/* Benefits row */
.tv-benefits__row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

/* Individual benefit item */
.tv-benefits__item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  margin-bottom: 40px;
}

/* Icon */
.tv-benefits__icon {
  color: #ffa100;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tv-benefits__icon svg {
  width: 32px;
  height: 32px;
}

/* Item title */
.tv-benefits__item-title {
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  font-size: 20px;
  line-height: 26px;
  font-weight: 700;
  text-transform: uppercase;
  margin: 0 0 10px 0;
  color: #333;
}

/* Item text */
.tv-benefits__item-text {
  font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 14px;
  line-height: 1.42857143;
  margin: 0;
  color: #333;
}

/* CTA row */
.tv-benefits__cta-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.tv-benefits__cta {
  font-weight: 700;
  color: #f6a400;
  text-decoration: none;
  transition: all 0.3s;
  font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 14px;
}

.tv-benefits__cta:hover {
  color: #333;
}

/* === Responsive === */
@media (max-width: 1200px) {
  .tv-benefits__item {
    width: 33.333333%;
  }
}

@media (max-width: 1024px) {
  .tv-benefits__item {
    width: 50%;
  }
}

@media (max-width: 767px) {
  .tv-benefits__icon {
    margin-top: 20px;
  }
}

@media (max-width: 750px) {
  .tv-benefits__item {
    width: 100%;
  }
}

@media (max-width: 500px) {
  .tv-benefits__title {
    font-size: 34px;
    line-height: 40px;
  }
  .tv-benefits__subtitle,
  .tv-benefits__item-title {
    font-size: 18px;
    line-height: 22px;
  }
  .tv-benefits__icon svg {
    width: 28px;
    height: 28px;
  }
}
{% endstylesheet %}

