@media (max-width: 550px) {
  .tv-reco__product-row {
    flex-direction: column;
    padding: 0 15px 15px;
  }
  .tv-reco__channels-wrap {
    padding: 0 15px 15px;
  }
  .tv-reco__product-img {
    width: 100%;
    max-width: 150px;
    margin: 0 auto 15px;
  }
  .tv-reco__product-info {
    width: 100%;
    margin-left: 0;
    padding: 0;
  }
  .tv-reco__product-actions {
    flex-direction: column;
    align-items: stretch;
  }
  .tv-reco__action-link {
    width: 100%;
    justify-content: center;
  }
  .tv-reco__add-btn {
    min-width: auto;
    width: 100%;
  }
  .tv-reco__ch-item {
    width: calc(14.28% - 3.43px);
  }
  .tv-reco__ch-item:nth-child(10n) {
    margin-right: 4px;
  }
  .tv-reco__ch-item:nth-child(7n) {
    margin-right: 0;
  }
}
