velStatus":"FAIR","signalLevelValue":-9.66},{"antenna":"148383","signalLevelStatus":"GOOD","signalLevelValue":-1.16},{"antenna":"149884","signalLevelStatus":"GOOD","signalLevelValue":-1.16}]}],"antennaGain":{"maxElectricFS":{"vhfL":0,"vhfH":84.63,"uhf":70.87},"antennas":[{"id":"148883","band":{"vhfL":-40,"vhfH":7,"uhf":15.5}},{"id":"144286","band":{"vhfL":-6,"vhfH":2,"uhf":10}},{"id":"148383","band":{"vhfL":8.5,"vhfH":8.5,"uhf":18.5}},{"id":"149884","band":{"vhfL":-40,"vhfH":8.5,"uhf":18.5}}]},"recommendation":{"antennaId":"144286","stations":[{"id":"59281","rfChannel":10,"azimuth":114,"distance":14.4,"channels":[{"callSign":"WBUPABC","network":"ABC","channelNumber":"10.1","isNextGen":false,"priority":true,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/abc.png"},{"callSign":"WBUP-CW","network":"CW+","channelNumber":"10.2","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/cwplus.png"}],"latitude":46.491,"longitude":-87.893,"signalLevelValue":4.33,"signalLevelStatus":"GOOD"},{"id":"81448","rfChannel":19,"azimuth":98,"distance":32.2,"channels":[{"callSign":"METV","network":"Me-TV","channelNumber":"19.1","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/me-tv.png"},{"callSign":"CBS","network":"CBS","channelNumber":"19.2","isNextGen":false,"priority":true,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/cbs.png"},{"callSign":"H and I","network":"Heroes & Icons","channelNumber":"19.3","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/heroes_and_icons.png"},{"callSign":"CourtTV","network":"Court TV","channelNumber":"19.4","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/court_tv.png"},{"callSign":"StartTV","network":"Start TV","channelNumber":"19.5","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/start_tv.png"},{"callSign":"ION","network":"ION","channelNumber":"19.7","isNextGen":false,"priority":false,"logo":"https://resources.televes.com/assets/images/logos/channels/usa/ion.png"}],"latitude":46.502,"longitude":-87.649,"signalLevelValue":-9.66,"signalLevelStatus":"FAIR"}]}}];

  /* ===== DOM ===== */
  var formWrap = document.getElementById('tvRecoForm');
  var formEl = document.getElementById('tvRecoFormEl');
  var input = document.getElementById('tvRecoInput');
  var errorEl = document.getElementById('tvRecoError');
  var loadingEl = document.getElementById('tvRecoLoading');
  var resultsEl = document.getElementById('tvRecoResults');
  var backBtn = document.getElementById('tvRecoBack');
  var locationEl = document.getElementById('tvRecoLocation');
  var groupsEl = document.getElementById('tvRecoGroups');

  /* ===== URL PARAMS ===== */
  function getUrlParam(name) {
    var params = new URLSearchParams(window.location.search);
    return params.get(name);
  }

  /* ===== GEOCODING ===== */
  function geocode(address, callback) {
    if (GOOGLE_KEY) {
      var url = 'https://maps.googleapis.com/maps/api/geocode/json?address=' + encodeURIComponent(address) + '&key=' + GOOGLE_KEY;
      fetch(url).then(function(r) { return r.json(); }).then(function(data) {
        if (data.results && data.results.length > 0) {
          var loc = data.results[0].geometry.location;
          callback(null, { lat: loc.lat, lng: loc.lng, display: data.results[0].formatted_address });
        } else {
          callback('Location not found. Please try a different address.');
        }
      }).catch(function() { callback('Geocoding failed. Please try again.'); });
    } else {
      var url = 'https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(address) + '&countrycodes=us&limit=1';
      fetch(url, { headers: { 'Accept-Language': 'en' } }).then(function(r) { return r.json(); }).then(function(data) {
        if (data && data.length > 0) {
          callback(null, { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon), display: data[0].display_name });
        } else {
          callback('Location not found. Please try a different address or ZIP code.');
        }
      }).catch(function() { callback('Geocoding failed. Please try again.'); });
    }
  }

  /* ===== GOOGLE PLACES AUTOCOMPLETE ===== */
  function initAutocomplete() {
    if (!GOOGLE_KEY || typeof google === 'undefined' || !google.maps || !google.maps.places) return;
    var autocomplete = new google.maps.places.Autocomplete(input, {
      types: ['geocode'],
      componentRestrictions: { country: 'us' }
    });
    autocomplete.addListener('place_changed', function() {
      var place = autocomplete.getPlace();
      if (place.geometry) {
        input.dataset.lat = place.geometry.location.lat();
        input.dataset.lng = place.geometry.location.lng();
        input.dataset.display = place.formatted_address || input.value;
      }
    });
  }

  /* ===== API CALL ===== */
  function fetchRecommendation(lat, lng, callback) {
    /* If demo mode, return demo data immediately */
    if (USE_DEMO) {
      setTimeout(function() { callback(null, DEMO_DATA); }, 800);
      return;
    }

    var url = TELEVES_API + '?latitude=' + lat + '&longitude=' + lng;
    fetch(url).then(function(r) {
      if (!r.ok) throw new Error('API error ' + r.status);
      return r.json();
    }).then(function(data) {
      callback(null, data);
    }).catch(function(err) {
      /* Fallback to demo data if API fails (CORS / mixed content) */
      console.warn('Televes API failed (' + err.message + '), using demo data.');
      callback(null, DEMO_DATA);
    });
  }

  /* ===== PROCESS RESULTS ===== */
  function processResults(data) {
    /* API returns an array of groups OR an object with .recommendation array */
    var groups;
    if (Array.isArray(data)) {
      groups = data;
    } else if (data && data.recommendation && Array.isArray(data.recommendation)) {
      groups = data.recommendation;
    } else {
      return null;
    }

    if (!groups.length) return null;

    var processed = [];

    groups.forEach(function(group, idx) {
      var azimuth = group.azimuth;
      var stations = group.stations || [];
      var recommendation = group.recommendation || {};
      var recommendedAntennaId = recommendation.antennaId || null;
      var recoStations = recommendation.stations || [];

      /* Collect all channels from ALL stations in this group */
      var priorityChannels = [];
      var allChannels = [];
      var seenPriority = {};
      var seenAll = {};

      stations.forEach(function(station) {
        (station.channels || []).forEach(function(ch) {
          var key = ch.network + '|' + ch.channelNumber;

          /* Determine signal status for this station with the recommended antenna */
          var signalStatus = 'NO_SIGNAL';
          if (recommendedAntennaId) {
            (station.antennaSignalLevels || []).forEach(function(asl) {
              if (asl.antenna === recommendedAntennaId) {
                signalStatus = asl.signalLevelStatus;
              }
            });
          }

          var chObj = {
            callSign: ch.callSign,
            network: ch.network,
            channelNumber: ch.channelNumber,
            isNextGen: ch.isNextGen,
            priority: ch.priority,
            logo: ch.logo,
            signalStatus: signalStatus
          };

          if (ch.priority && !seenPriority[key]) {
            seenPriority[key] = true;
            priorityChannels.push(chObj);
          }
          if (!seenAll[key]) {
            seenAll[key] = true;
            allChannels.push(chObj);
          }
        });
      });

      /* Also gather channels from recommendation.stations (they have per-station signal info) */
      recoStations.forEach(function(rs) {
        (rs.channels || []).forEach(function(ch) {
          var key = ch.network + '|' + ch.channelNumber;
          var chObj = {
            callSign: ch.callSign,
            network: ch.network,
            channelNumber: ch.channelNumber,
            isNextGen: ch.isNextGen,
            priority: ch.priority,
            logo: ch.logo,
            signalStatus: rs.signalLevelStatus || 'GOOD'
          };
          if (ch.priority && !seenPriority[key]) {
            seenPriority[key] = true;
            priorityChannels.push(chObj);
          }
          if (!seenAll[key]) {
            seenAll[key] = true;
            allChannels.push(chObj);
          }
        });
      });

      /* Sort: priority first, then alphabetical */
      priorityChannels.sort(function(a, b) { return (a.network || '').localeCompare(b.network || ''); });
      allChannels.sort(function(a, b) {
        if (a.priority && !b.priority) return -1;
        if (!a.priority && b.priority) return 1;
        return (a.network || '').localeCompare(b.network || '');
      });

      /* Non-priority channels */
      var otherChannels = allChannels.filter(function(ch) { return !ch.priority; });

      processed.push({
        index: idx,
        azimuth: azimuth,
        stations: stations,
        recommendedAntennaId: recommendedAntennaId,
        recoStations: recoStations,
        priorityChannels: priorityChannels,
        allChannels: allChannels,
        otherChannels: otherChannels,
        totalStations: stations.length
      });
    });

    return processed;
  }

  /* ===== FETCH SHOPIFY PRODUCT ===== */
  var productCache = {};
  function fetchProduct(handle, callback) {
    if (productCache[handle]) { callback(productCache[handle]); return; }
    fetch('/products/' + handle + '.js').then(function(r) {
      if (!r.ok) return callback(null);
      return r.json();
    }).then(function(p) {
      if (p) productCache[handle] = p;
      callback(p || null);
    }).catch(function() { callback(null); });
  }

  /* ===== HELPERS ===== */
  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.style.display = 'block';
  }

  function hideError() { errorEl.style.display = 'none'; }

  function showState(state) {
    formWrap.style.display = state === 'form' ? '' : 'none';
    loadingEl.style.display = state === 'loading' ? 'flex' : 'none';
    resultsEl.style.display = state === 'results' ? '' : 'none';
  }

  function formatMoney(cents) { return '$' + (cents / 100).toFixed(2); }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ===== RENDER RESULTS ===== */
  function renderResults(groups, displayAddress) {
    if (!groups || !groups.length) {
      showState('form');
      showError('No stations found for your location. Try a different address.');
      return;
    }

    /* Location */
    var totalStations = 0;
    var totalChannels = 0;
    var seenCh = {};
    groups.forEach(function(g) {
      totalStations += g.totalStations;
      g.allChannels.forEach(function(ch) {
        var k = ch.network + '|' + ch.channelNumber;
        if (!seenCh[k]) { seenCh[k] = true; totalChannels++; }
      });
    });

    locationEl.innerHTML = '<p class="tv-reco__location-text"><strong>Results for:</strong> ' + escapeHtml(displayAddress) + '</p>';

    /* Render each group */
    var groupsHTML = '';

    groups.forEach(function(group, gIdx) {
      var isFirst = gIdx === 0;
      var az = group.azimuth;
      var antennaId = group.recommendedAntennaId;
      var antennaInfo = antennaId ? ANTENNA_MAP[antennaId] : null;
      var groupCls = 'tv-reco__group' + (isFirst ? ' tv-reco__group--first' : '');
      var groupNum = gIdx + 1;

      groupsHTML += '<div class="' + groupCls + '" id="tvRecoGroup_' + gIdx + '">';

      /* Number circle */
      groupsHTML += '<div class="tv-reco__group-number"><div class="tv-reco__number-circle">' + groupNum + '</div></div>';

      /* Azimuth header */
      if (az) {
        groupsHTML += '<div class="tv-reco__group-direction"><p>antenna pointed to <strong>' + az.mean + 'º</strong></p></div>';
      }

      /* Product card */
      if (antennaInfo) {
        groupsHTML += '<div class="tv-reco__product-row" id="tvRecoProd_' + gIdx + '">';

        /* Product image */
        groupsHTML += '<div class="tv-reco__product-img" id="tvRecoImg_' + gIdx + '">';
        groupsHTML += '<div class="tv-reco__product-img-placeholder"></div>';
        groupsHTML += '</div>';

        /* Product info */
        groupsHTML += '<div class="tv-reco__product-info">';
        groupsHTML += '<a href="/products/' + antennaInfo.handle + '" class="tv-reco__product-title-link"><div class="tv-reco__product-title">' + escapeHtml(antennaInfo.name) + '</div></a>';
        groupsHTML += '<div class="tv-reco__product-desc" id="tvRecoDesc_' + gIdx + '"></div>';
        groupsHTML += '<div class="tv-reco__product-price" id="tvRecoPrice_' + gIdx + '"></div>';
        groupsHTML += '<div class="tv-reco__product-cart" id="tvRecoCart_' + gIdx + '"></div>';
        groupsHTML += '</div>';

        /* Action links */
        groupsHTML += '<div class="tv-reco__product-actions">';
        groupsHTML += '<a href="/products/' + antennaInfo.handle + '" class="tv-reco__action-link"><span>Go to the product</span></a>';
        groupsHTML += '</div>';

        groupsHTML += '</div>';
      }

      /* Channels section */
      groupsHTML += '<div class="tv-reco__channels-wrap">';

      /* "With this antenna, you will watch all these channels:" */
      groupsHTML += '<p class="tv-reco__channels-intro"><strong>With this antenna, you will watch all these channels:</strong></p>';

      /* Priority channels row */
      groupsHTML += '<div class="tv-reco__channel-grid" id="tvRecoPriorityCh_' + gIdx + '">';
      group.priorityChannels.forEach(function(ch) {
        groupsHTML += renderChannelItem(ch);
      });
      groupsHTML += '</div>';

      /* All channels (initially hidden) */
      if (group.otherChannels.length > 0) {
        groupsHTML += '<div class="tv-reco__channel-grid tv-reco__channel-grid--all" id="tvRecoAllCh_' + gIdx + '" style="display:none;">';
        group.otherChannels.forEach(function(ch) {
          groupsHTML += renderChannelItem(ch);
        });
        groupsHTML += '</div>';

        groupsHTML += '<div class="tv-reco__channels-toggle">';
        groupsHTML += '<button class="tv-reco__toggle-btn tv-reco__toggle-show" id="tvRecoShowMore_' + gIdx + '" type="button" data-group="' + gIdx + '">See ' + group.otherChannels.length + ' more channels</button>';
        groupsHTML += '<button class="tv-reco__toggle-btn tv-reco__toggle-hide" id="tvRecoShowLess_' + gIdx + '" type="button" data-group="' + gIdx + '" style="display:none;">See less channels</button>';
        groupsHTML += '</div>';
      }

      groupsHTML += '</div>'; /* channels-wrap */
      groupsHTML += '</div>'; /* group */
    });

    groupsEl.innerHTML = groupsHTML;

    /* Bind show more/less buttons */
    groups.forEach(function(group, gIdx) {
      var showMoreBtn = document.getElementById('tvRecoShowMore_' + gIdx);
      var showLessBtn = document.getElementById('tvRecoShowLess_' + gIdx);
      var allChEl = document.getElementById('tvRecoAllCh_' + gIdx);

      if (showMoreBtn && showLessBtn && allChEl) {
        showMoreBtn.addEventListener('click', function() {
          allChEl.style.display = '';
          showMoreBtn.style.display = 'none';
          showLessBtn.style.display = '';
        });
        showLessBtn.addEventListener('click', function() {
          allChEl.style.display = 'none';
          showMoreBtn.style.display = '';
          showLessBtn.style.display = 'none';
        });
      }
    });

    /* Fetch product data for each group */
    groups.forEach(function(group, gIdx) {
      var antennaId = group.recommendedAntennaId;
      var antennaInfo = antennaId ? ANTENNA_MAP[antennaId] : null;
      if (!antennaInfo) return;

      fetchProduct(antennaInfo.handle, function(product) {
        var imgEl = document.getElementById('tvRecoImg_' + gIdx);
        var descEl = document.getElementById('tvRecoDesc_' + gIdx);
        var priceEl = document.getElementById('tvRecoPrice_' + gIdx);
        var cartEl = document.getElementById('tvRecoCart_' + gIdx);

        if (!product) {
          if (descEl) descEl.innerHTML = '<p>' + escapeHtml(antennaInfo.range) + ' &middot; ' + escapeHtml(antennaInfo.pattern) + '</p>';
          return;
        }

        if (imgEl && product.featured_image) {
          imgEl.innerHTML = '<a href="/products/' + antennaInfo.handle + '"><img src="' + product.featured_image.replace(/(\.\w+)$/, '_400x$1') + '" alt="' + escapeHtml(product.title) + '" loading="lazy"></a>';
        }

        if (descEl) {
          var desc = product.description ? product.description.replace(/<[^>]*>/g, '') : '';
          if (desc.length > 120) desc = desc.substring(0, 120) + '...';
          descEl.innerHTML = '<p>' + escapeHtml(desc) + '</p>';
        }

        if (priceEl) {
          priceEl.innerHTML = '<span class="tv-reco__price">' + formatMoney(product.price) + '</span>';
        }

        if (cartEl && product.variants && product.variants.length > 0) {
          cartEl.innerHTML = '<form method="post" action="/cart/add">' +
            '<input type="hidden" name="id" value="' + product.variants[0].id + '">' +
            '<input type="hidden" name="quantity" value="1">' +
            '<button type="submit" class="tv-reco__add-btn"><span>Add to Cart</span></button>' +
          '</form>';
        }
      });
    });

    showState('results');
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderChannelItem(ch) {
    var signalCls = '';
    if (ch.signalStatus === 'GOOD') signalCls = 'tv-reco__signal--good';
    else if (ch.signalStatus === 'FAIR') signalCls = 'tv-reco__signal--fair';

    var logoHTML = ch.logo
      ? '<img src="' + escapeHtml(ch.logo) + '" alt="' + escapeHtml(ch.network) + '" loading="lazy">'
      : '<span class="tv-reco__ch-letter">' + escapeHtml((ch.network || '?').charAt(0)) + '</span>';

    return '<div class="tv-reco__ch-item" title="' + escapeHtml(ch.network + ' ' + ch.channelNumber) + '">' +
      '<div class="tv-reco__ch-logo">' + logoHTML + '</div>' +
      '<div class="tv-reco__ch-info">' +
        '<div class="tv-reco__ch-name">' + escapeHtml(ch.network || ch.callSign) + '</div>' +
        '<div class="tv-reco__ch-signal ' + signalCls + '"></div>' +
      '</div>' +
    '</div>';
  }

  /* ===== EVENTS ===== */
  formEl.addEventListener('submit', function(e) {
    e.preventDefault();
    hideError();
    var val = input.value.trim();
    if (!val) return;

    var hasCoords = input.dataset.lat && input.dataset.lng;
    showState('loading');

    function doApiCall(lat, lng, display) {
      fetchRecommendation(lat, lng, function(err, data) {
        if (err) {
          showState('form');
          showError(err);
          return;
        }
        var groups = processResults(data);
        renderResults(groups, display);
      });
    }

    if (hasCoords) {
      doApiCall(parseFloat(input.dataset.lat), parseFloat(input.dataset.lng), input.dataset.display || val);
      input.dataset.lat = '';
      input.dataset.lng = '';
    } else {
      geocode(val, function(err, loc) {
        if (err) {
          showState('form');
          showError(err);
          return;
        }
        doApiCall(loc.lat, loc.lng, loc.display || val);
      });
    }
  });

  backBtn.addEventListener('click', function() {
    showState('form');
    input.value = '';
    input.focus();
  });

  /* Load Google Places if key provided */
  if (GOOGLE_KEY) {
    var s = document.createElement('script');
    s.src = 'https://maps.googleapis.com/maps/api/js?key=' + GOOGLE_KEY + '&libraries=places&callback=__tvRecoInitAC';
    s.async = true;
    s.defer = true;
    window.__tvRecoInitAC = initAutocomplete;
    document.head.appendChild(s);
  }

  /* ===== AUTO-SEARCH FROM URL PARAMS ===== */
  /* When arriving from the homepage form, ?address=... is in the URL */
  var urlAddress = getUrlParam('address');
  if (urlAddress) {
    input.value = urlAddress;
    showState('loading');

    geocode(urlAddress, function(err, loc) {
      if (err) {
        showState('form');
        showError(err);
        return;
      }
      fetchRecommendation(loc.lat, loc.lng, function(apiErr, data) {
        if (apiErr) {
          showState('form');
          showError(apiErr);
          return;
        }
        var groups = processResults(data);
        renderResults(groups, loc.display || urlAddress);
      });
    });
  }
})();
</script>

