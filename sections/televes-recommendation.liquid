{%- comment -%}
  Televes Antenna Recommendation Tool
  ZIP/address → geocode → Televes API → recommended antenna + channels
  1:1 clone of store.televes.com recommendation page
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | default: 'Find Your Best Antenna'
  assign description = section.settings.description | default: 'Enter your address or ZIP code and we will recommend the best antenna for your location.'
  assign input_placeholder = section.settings.input_placeholder | default: 'Enter your address or ZIP code'
  assign btn_text = section.settings.btn_text | default: 'Find my antenna'
  assign google_api_key = section.settings.google_api_key
  assign api_proxy_url = section.settings.api_proxy_url
-%}

<section class="tv-reco" id="tv-reco-{{ section.id }}">
  <div class="tv-reco__container">

    {%- comment -%} ===== FORM STATE ===== {%- endcomment -%}
    <div class="tv-reco__form-wrap" id="tvRecoForm">
      <div class="tv-reco__separator"></div>
      <h1 class="tv-reco__heading">{{ heading }}</h1>
      <p class="tv-reco__desc">{{ description }}</p>
      <form class="tv-reco__form" id="tvRecoFormEl" autocomplete="off">
        <div class="tv-reco__search">
          <input type="text" id="tvRecoInput" class="tv-reco__input" placeholder="{{ input_placeholder }}" required>
          <button type="submit" class="tv-reco__submit" id="tvRecoBtn">
            <span>{{ btn_text }}</span>
          </button>
        </div>
      </form>
      <div class="tv-reco__error" id="tvRecoError" style="display:none;"></div>
    </div>

    {%- comment -%} ===== LOADING STATE ===== {%- endcomment -%}
    <div class="tv-reco__loading" id="tvRecoLoading" style="display:none;">
      <div class="tv-reco__spinner"></div>
      <p>Analyzing signal coverage for your area...</p>
    </div>

    {%- comment -%} ===== RESULTS STATE ===== {%- endcomment -%}
    <div class="tv-reco__results" id="tvRecoResults" style="display:none;">
      <button class="tv-reco__back" id="tvRecoBack" type="button">&larr; New search</button>

      {%- comment -%} Location summary {%- endcomment -%}
      <div class="tv-reco__location" id="tvRecoLocation"></div>

      {%- comment -%} Results heading {%- endcomment -%}
      <div class="tv-reco__results-header">
        <div class="tv-reco__separator"></div>
        <h2 class="tv-reco__results-heading">HERE IS OUR ANTENNA RECOMMENDATION!</h2>
      </div>

      {%- comment -%} Groups container (dynamically filled) {%- endcomment -%}
      <div class="tv-reco__groups" id="tvRecoGroups"></div>
    </div>

  </div>
</section>

