{% schema %}
{
  "name": "Televes Recommendation",
  "tag": "section",
  "class": "tv-section-recommendation",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Best Antenna"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Enter your address or ZIP code and we will recommend the best antenna for your location."
